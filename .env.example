# PostgreSQL (used by main.py and postgres_driver.py)
# На сервере в Docker, если PostgreSQL на хосте: DB_HOST=host.docker.internal
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm
DB_PASSWORD=change_me

# Optional: single connection string instead of DB_* variables above
# DATABASE_URL=postgresql+psycopg://crm:change_me@localhost:5432/crm_db

# Backend (на сервере используется 8001, т.к. 8000 занят)
PORT=8001

# Landing server
LANDING_PORT=8080
# Локально: http://127.0.0.1:8001/lead
# На сервере в Docker CRM_API_URL задаётся в deploy.yml (http://vmeste-api:8001/lead)
CRM_API_URL=http://127.0.0.1:8001/lead
MIN_FORM_FILL_SECONDS=3
LANDING_1_SOURCE=landing_1
LANDING_2_SOURCE=landing_2

# Rate limiting (Redis recommended; falls back to memory:// if unavailable)
# Локально: redis://127.0.0.1:6379/0
# На сервере, если Redis на хосте: redis://host.docker.internal:6379/0
RATE_LIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# UniSender email integration
UNISENDER_API_KEY=your_unisender_api_key
# Базовый fallback-список (используется, если для source нет явной настройки ниже)
UNISENDER_LIST_IDS=123456
# Разные списки для разных источников (формат: source:list_id;source:list_id)
# Пример: landing_1:111111;landing_2:222222;landing_3:333333
UNISENDER_LIST_IDS_BY_SOURCE=landing_1:111111;landing_2:222222
UNISENDER_SENDER_NAME=VMESTE
UNISENDER_SENDER_EMAIL=noreply@your-domain.ru
UNISENDER_MATERIAL_SUBJECT=Ваш чек-лист
UNISENDER_MATERIAL_URL=http://127.0.0.1:8001/materials/checklist.pdf
UNISENDER_ALLOWED_SOURCES=landing_1,landing_2
